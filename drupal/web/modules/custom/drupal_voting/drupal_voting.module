<?php

declare(strict_types=1);

/**
 * @file
 * Provides a question entity type.
 */

use Drupal\Core\Render\Element;
use Drupal\user\UserInterface;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_theme().
 */
function drupal_voting_theme(array $existing, string $type, string $theme, string $path,): array {
  return [
    'drupal_voting_vote_option' => [
      'render element' => 'element',
      'template' => 'drupal-voting-vote-option',
    ],
    'drupal_voting_results' => [
      'variables' => [
        'question_title' => NULL,
        'results' => [],
        'back_url' => NULL,
      ],
    ],
  ];
}


/**
 * Implements hook_user_cancel().
 */
function drupal_voting_user_cancel($edit, UserInterface $account, $method): void {
  //@TODO move this logic to a service
  switch ($method) {
    case 'user_cancel_block_unpublish':
      // Unpublish questions and question options.
      $voting_question_storage = \Drupal::entityTypeManager()->getStorage('drupal_voting_question');
      $voting_question_option_storage = \Drupal::entityTypeManager()->getStorage('drupal_voting_question_option');
    
      $drupal_voting_question_ids = $voting_question_storage->getQuery()
        ->condition('uid', $account->id())
        ->condition('status', 1)
        ->accessCheck(FALSE)
        ->execute();
      foreach ($voting_question_storage->loadMultiple($drupal_voting_question_ids) as $drupal_voting_question) {
        $drupal_voting_question->set('status', FALSE)->save();
      }
 
      $drupal_voting_question_option_ids = $voting_question_option_storage->getQuery()
        ->condition('uid', $account->id())
        ->condition('status', 1)
        ->accessCheck(FALSE)
        ->execute();
      foreach ($voting_question_option_storage->loadMultiple($drupal_voting_question_option_ids) as $drupal_voting_question_option) {
        $drupal_voting_question_option->set('status', FALSE)->save();
      }

      break;

    case 'user_cancel_reassign':
      // Anonymize questions and question options.
      $voting_question_storage = \Drupal::entityTypeManager()->getStorage('drupal_voting_question');
      $voting_question_option_storage = \Drupal::entityTypeManager()->getStorage('drupal_voting_question_option');

      $drupal_voting_question_ids = $voting_question_storage->getQuery()
        ->condition('uid', $account->id())
        ->accessCheck(FALSE)
        ->execute();
      foreach ($voting_question_storage->loadMultiple($drupal_voting_question_ids) as $drupal_voting_question) {
        $drupal_voting_question->setOwnerId(0)->save();
      }
      
      $drupal_voting_question_option_ids = $voting_question_option_storage->getQuery()
        ->condition('uid', $account->id())
        ->accessCheck(FALSE)
        ->execute();
      foreach ($voting_question_option_storage->loadMultiple($drupal_voting_question_option_ids) as $drupal_voting_question_option) {
        $drupal_voting_question_option->setOwnerId(0)->save();
      }
      
      break;
  }
}

/**
 * Implements hook_ENTITY_TYPE_predelete() for user entities.
 */
function drupal_voting_user_predelete(UserInterface $account): void {
  // Delete questions that belong to this account.

  //@TODO move this logic to a service
  $voting_question_storage = \Drupal::entityTypeManager()->getStorage('drupal_voting_question');
  $question_option_storage = \Drupal::entityTypeManager()->getStorage('drupal_voting_question_option');

  $drupal_voting_question_ids = $voting_question_storage->getQuery()
    ->condition('uid', $account->id())
    ->accessCheck(FALSE)
    ->execute();
  $voting_question_storage->delete(
    $voting_question_storage->loadMultiple($drupal_voting_question_ids)
  );

  
  $drupal_voting_question_option_ids = $question_option_storage->getQuery()
    ->condition('uid', $account->id())
    ->accessCheck(FALSE)
    ->execute();
  $question_option_storage->delete(
    $question_option_storage->loadMultiple($drupal_voting_question_option_ids)
  );
}

/**
 * Implements hook_form_FORM_ID_alter().
 * 
 * We could use an Event Subscriber, but we
 * decide to go with simplicity.
 */
function drupal_voting_form_user_login_form_alter(array &$form,FormStateInterface $form_state,): void {
  $form['#submit'][] = '_drupal_voting_user_login_redirect_submit';
}

/**
 * Redirects voters to the question list after login.
 */
function _drupal_voting_user_login_redirect_submit(array &$form, FormStateInterface $form_state,): void {
  $account = \Drupal::currentUser();

  if ($account->isAuthenticated() && in_array('voter', $account->getRoles(), TRUE)) {
    $form_state->setRedirect('drupal_voting.question_list');
  }
}